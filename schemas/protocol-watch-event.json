{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://luiscore.com/schemas/protocol-watch-event.json",
  "title": "LuisCore Protocol Watch Event",
  "description": "Operational protocol event row from GET /api/protocol-watch.",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "ts", "level"],
  "properties": {
    "kind": {
      "type": "string",
      "description": "Event kind (SPFD, PROTOCOL, FORK, VERIFIER, …)."
    },
    "ts": { "type": "string", "format": "date-time" },
    "level": {
      "type": "string",
      "enum": ["debug", "info", "warn", "error"],
      "description": "Severity level."
    }
  }
}
